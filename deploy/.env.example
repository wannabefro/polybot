# Polybot Environment Configuration
# Copy to /opt/polybot/.env and fill in values.
#
# WARNING: systemd EnvironmentFile does NOT support inline comments.
# Do NOT put # comments on the same line as a value.

# L1 private key (hex, with or without 0x prefix)
POLYBOT_PRIVATE_KEY=

# Network
POLYBOT_CLOB_HOST=https://clob.polymarket.com
POLYBOT_GAMMA_HOST=https://gamma-api.polymarket.com
POLYBOT_CHAIN_ID=137

# Mode (true = paper trading, no real orders)
POLYBOT_PAPER_MODE=true

# Starting NAV in USDC
POLYBOT_NAV_USDC=10000.0

# Risk limits (fractions of NAV)
POLYBOT_MAX_NOTIONAL_PCT=0.02
POLYBOT_MAX_GROSS_PCT=0.25
POLYBOT_MAX_INVENTORY_PCT=0.01
POLYBOT_DAILY_LOSS_PCT=0.03

# Timing (seconds unless noted)
POLYBOT_HEARTBEAT_SECS=5
POLYBOT_GEOBLOCK_POLL_SECS=900
POLYBOT_DISCOVERY_SECS=60
POLYBOT_RECON_SECS=45
POLYBOT_STALE_FEED_MS=1500

# Mean reversion strategy
POLYBOT_MR_MAX_NAV_PCT=0.005
POLYBOT_MR_MIN_VOL_24H=10000.0

# Decay strategy
POLYBOT_DECAY_MIN_PRICE=0.80
POLYBOT_DECAY_SPORTS_MIN_PRICE=0.90
POLYBOT_DECAY_MAX_BET_USDC=15.0
POLYBOT_DECAY_SPORTS_MAX_BET_USDC=5.0
POLYBOT_DECAY_WINDOW_HOURS=24.0
POLYBOT_DECAY_SPORTS_WINDOW_HOURS=0.083
POLYBOT_DECAY_NAV_FRACTION=0.70
POLYBOT_DECAY_EXCLUDED_TAGS=crypto,bitcoin,ethereum,btc,eth

# Hedge timeout (seconds)
POLYBOT_HEDGE_TIMEOUT_SECS=120

# Sizing (USDC)
POLYBOT_MM_MIN_SIZE=1.0
POLYBOT_REWARD_MIN_SIZE=1.0
POLYBOT_REWARD_MIN_NAV_USDC=25.0
POLYBOT_MR_MIN_NAV_USDC=100.0

# Small account thresholds
POLYBOT_SMALL_ACCOUNT_NAV_THRESHOLD=500.0
POLYBOT_SMALL_MIN_PER_MARKET_PCT=0.08
POLYBOT_SMALL_MIN_INVENTORY_PCT=0.06

# WebSocket
POLYBOT_MAX_WS_TOKENS=500

# SOCKS5 proxy (optional, for geo-restricted regions)
# NORDVPN_USERNAME=
# NORDVPN_PASSWORD=
# NORDVPN_HOST=se.socks.nordhold.net

# LLM signal (optional)
# POLYBOT_LLM_ENDPOINT=http://localhost:8080/signal

# Logging
RUST_LOG=polybot=info
