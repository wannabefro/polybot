# Polybot Environment Configuration
# Copy to /opt/polybot/.env and fill in values.

# === Required ===
POLYBOT_PRIVATE_KEY=           # L1 private key (hex, with or without 0x prefix)

# === Network ===
POLYBOT_CLOB_HOST=https://clob.polymarket.com
POLYBOT_GAMMA_HOST=https://gamma-api.polymarket.com
POLYBOT_CHAIN_ID=137           # Polygon mainnet

# === Mode ===
POLYBOT_PAPER_MODE=true        # Start in paper mode (no real orders)

# === NAV ===
POLYBOT_NAV_USDC=10000.0       # Total NAV in USDC

# === Risk Limits (fractions of NAV) ===
POLYBOT_MAX_NOTIONAL_PCT=0.02          # 2% per market
POLYBOT_MAX_GROSS_PCT=0.25             # 25% total
POLYBOT_MAX_INVENTORY_PCT=0.01         # 1% per outcome
POLYBOT_DAILY_LOSS_PCT=0.03            # 3% daily loss halt

# === Timing ===
POLYBOT_HEARTBEAT_SECS=5
POLYBOT_GEOBLOCK_POLL_SECS=900
POLYBOT_DISCOVERY_SECS=60
POLYBOT_RECON_SECS=45
POLYBOT_STALE_FEED_MS=1500

# === Mean Reversion Strategy ===
POLYBOT_MR_MAX_NAV_PCT=0.005           # 0.5% NAV cap
POLYBOT_MR_MIN_VOL_24H=10000.0         # Minimum 24h volume

# === Decay Strategy ===
POLYBOT_DECAY_MIN_PRICE=0.80           # Min price for decay candidates
POLYBOT_DECAY_MAX_BET=15.0             # Max USDC per decay position
POLYBOT_DECAY_WINDOW_HOURS=168         # Look-ahead window (hours to resolution)
POLYBOT_DECAY_NAV_FRACTION=0.70        # Max fraction of NAV for decay

# === Hedge ===
POLYBOT_HEDGE_TIMEOUT_MS=500           # 500ms hedge SLA

# === Sizing ===
POLYBOT_MM_MIN_SIZE=1.0                # Min quote size (USDC)
POLYBOT_REWARD_MIN_SIZE=1.0            # Min reward quote size (USDC)
POLYBOT_REWARD_MIN_NAV_USDC=25.0       # Min NAV to enable rewards
POLYBOT_MR_MIN_NAV_USDC=100.0          # Min NAV to enable mean-revert

# === Small Account ===
POLYBOT_SMALL_ACCOUNT_NAV_THRESHOLD=500.0  # NAV below this gets boosted caps
POLYBOT_SMALL_MIN_PER_MARKET_PCT=0.08      # 8% per market floor (small acct)
POLYBOT_SMALL_MIN_INVENTORY_PCT=0.06       # 6% inventory floor (small acct)

# === WebSocket ===
POLYBOT_MAX_WS_TOKENS=500              # Max tokens to subscribe via WS

# === SOCKS5 Proxy (optional, for geo-restricted regions) ===
# NORDVPN_USERNAME=                    # NordVPN service username
# NORDVPN_PASSWORD=                    # NordVPN service password
# NORDVPN_HOST=se.socks.nordhold.net   # SOCKS5 host (Sweden/Finland only — US/NL blocked)

# === LLM (optional) ===
# POLYBOT_LLM_ENDPOINT=http://localhost:8080/signal
# POLYBOT_LLM_TIMEOUT_MS=1500

# === Logging ===
RUST_LOG=polybot=info
